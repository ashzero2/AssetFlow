{
  "expo": {
    "name": "AssetFlow",
    "slug": "assetflow",
    "description": "Finance & Assets Manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "finsh",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E4EDE7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.assetflow"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#E4EDE7",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.assetflow"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1faf829e-3518-4d98-94e3-5334f8720390"
      }
    },
    "owner": "rahulaswin"
  }
}
